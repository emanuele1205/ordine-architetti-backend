{
  "name": "ordine-architetti-caltanissetta-backend",
  "version": "1.0.0",
  "description": "Backend API per l'app dell'Ordine degli Architetti P.P.C. della Provincia di Caltanissetta",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node -e \"console.log('✅ All modules OK'); require('./src/app');\"",
    "init-data": "node -e \"require('./src/services/data.service').initializeDefaultData();\"",
    "migrate": "node scripts/migrate-to-mongodb.js"
  },
  "keywords": [
    "ordine",
    "architetti",
    "caltanissetta",
    "api",
    "nodejs",
    "express"
  ],
  "author": "Ordine Architetti P.P.C. Caltanissetta",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.2.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "jest": "^29.6.1",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  }
